<controls:FancyWindow xmlns="https://spacestation14.io"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
        Title="{Loc au14-objectives-console-title}"
        MinSize="800 700">
    <BoxContainer Orientation="Vertical" Margin="8 8">
        <controls:StripeBack>
            <Label Text="{Loc au14-objectives-console-title}" HorizontalAlignment="Center"/>
        </controls:StripeBack>
        <BoxContainer Orientation="Horizontal" Margin="0 4 0 4">
            <Label Name="CurrentWinPointsLabel" Text=""/>
            <Control MinSize="16 0" />
            <Label Name="RequiredWinPointsLabel" Text=""/>
        </BoxContainer>
        <ScrollContainer VerticalExpand="true">
            <BoxContainer Name="ObjectivesList" Orientation="Vertical"/>
        </ScrollContainer>
    </BoxContainer>
</controls:FancyWindow>
