<controls:StaffHelpWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._RMC14.Mentor"
    Title="Admin and Mentor Help">
    <PanelContainer StyleClasses="CrtPanel" HorizontalExpand="True" VerticalExpand="True">
        <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="8">
            <PanelContainer StyleClasses="CrtInsetPanel" HorizontalExpand="True">
                <BoxContainer Orientation="Vertical" Margin="8 6" SeparationOverride="5">
                    <RichTextLabel Text="For reporting issues with another player to an admin, or asking about the rules" />
                    <Button Name="AdminHelpButton" Access="Public" Text="Admin Help" />
                </BoxContainer>
            </PanelContainer>
            <PanelContainer StyleClasses="CrtInsetPanel" HorizontalExpand="True">
                <BoxContainer Orientation="Vertical" Margin="8 6" SeparationOverride="5">
                    <RichTextLabel Text="For asking questions about the game" />
                    <Button Name="MentorHelpButton" Access="Public" Text="Mentor Help" />
                </BoxContainer>
            </PanelContainer>
        </BoxContainer>
    </PanelContainer>
</controls:StaffHelpWindow>
