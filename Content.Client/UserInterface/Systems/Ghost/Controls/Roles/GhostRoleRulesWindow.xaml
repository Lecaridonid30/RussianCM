<DefaultWindow xmlns="https://spacestation14.io"
               Title="{Loc 'ghost-roles-window-title'}"
               MinSize="560 340"
               SetSize="560 340">
    <PanelContainer StyleClasses="CrtPanel" HorizontalExpand="True" VerticalExpand="True">
        <BoxContainer Orientation="Vertical"
                      HorizontalExpand="True"
                      VerticalExpand="True"
                      SeparationOverride="10"
                      Margin="10">
            <PanelContainer StyleClasses="CrtInsetPanel" HorizontalExpand="True" VerticalExpand="True">
                <ScrollContainer HorizontalExpand="True"
                                 VerticalExpand="True"
                                 HScrollEnabled="False">
                    <RichTextLabel Name="TopBanner"
                                   HorizontalExpand="True"
                                   Margin="10 8" />
                </ScrollContainer>
            </PanelContainer>
            <Button Name="RequestButton"
                    Text="{Loc 'ghost-roles-window-request-role-button'}"
                    Disabled="True"
                    TextAlign="Center"
                    ClipText="True"
                    HorizontalAlignment="Center"
                    MinWidth="180"
                    MinHeight="34"
                    SetHeight="34" />
        </BoxContainer>
    </PanelContainer>
</DefaultWindow>
